PROJECT_NAME=CryptoPulse AI
ENVIRONMENT=development

POSTGRES_DB=cryptopulse
POSTGRES_USER=cryptopulse
POSTGRES_PASSWORD=cryptopulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

KAFKA_BROKER=kafka:9092
MARKET_TOPIC=market.ticks
TRACKED_PAIRS=btcusdt,ethusdt,solusdt,adausdt
INGESTION_POSTGRES_URL=postgresql://cryptopulse:cryptopulse@localhost:5432/cryptopulse
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
INGESTION_REFRESH_INTERVAL_SECONDS=300
STREAMING_POSTGRES_URL=postgresql://cryptopulse:cryptopulse@localhost:5432/cryptopulse
STREAMING_CONSUMER_GROUP=cryptopulse-indicator-processor
STREAMING_POLL_TIMEOUT_MS=5000

REALTIME_POSTGRES_URL=postgresql://cryptopulse:cryptopulse@localhost:5432/cryptopulse
REALTIME_CONSUMER_GROUP=cryptopulse-realtime-detector
REALTIME_POLL_TIMEOUT_MS=1000
REALTIME_WINDOW_SIZE=60
REALTIME_Z_THRESHOLD=3.0
REALTIME_MIN_SAMPLES=10

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change-me-in-production
SEED_DEMO_USER=false
SEED_DEMO_ALERTS=false

# Alert notifications (all optional; leave blank to disable a channel).
# ALERT_WEBHOOK_URL works with Discord/Slack incoming webhooks or any HTTP endpoint.
ALERT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

AGENT_HOST=0.0.0.0
AGENT_PORT=8080
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

VITE_API_BASE_URL=http://localhost:8000
VITE_AGENT_BASE_URL=http://localhost:8080
